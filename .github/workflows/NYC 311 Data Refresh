name: NYC 311 Data Refresh

on:
  workflow_dispatch: # يسمح لكِ بتشغيل الروبوت يدوياً في أي وقت

jobs:
  refresh-data:
    runs-on: ubuntu-latest
    permissions:
      contents: 'read'
      id-token: 'write' # ضروري جداً لاستخدام Workload Identity

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Authenticate to Google Cloud
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: 'projects/113456966208/locations/global/workloadIdentityPools/depi-pool/providers/github-new-provider'
          service_account: 'dbt-user-311@depi-graduation-project-489604.iam.gserviceaccount.com'

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Run Refresh Script
        run: |
          echo "سيتم هنا وضع كود بايثون الخاص بسحب البيانات في الخطوة القادمة"
